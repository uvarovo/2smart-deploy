# ============================================================================
# 2Smart Standalone — environment variables
# Copy this file to `.env` and fill in real values before running the stack.
# ============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Absolute path to this project on the host (used by docker-compose volumes).
# Must match the directory where docker-compose.yml lives.
ROOT_DIR_2SMART=/opt/2smart

# Display / access host for the UI. Set to your domain or public IP.
HOSTNAME=2smart.example.com

# Name shown in browser tabs / Market, etc.
SMART_DOMAIN=

# HTTPS port exposed by nginx. 443 is the default; change if already busy.
NGINX_HTTPS_PORT=443

# System timezone (e.g. Europe/Moscow, Europe/Kyiv, UTC).
TIMEZONE=UTC

# ---------------------------------------------------------------------------
# MQTT (EMQX) — used internally by all bridges and UI
# MQTT_URI is the internal broker URL reachable from the 2smart-core container.
# Do NOT change the hostname (`2smart-emqx`) — it is a docker-compose service name.
# ---------------------------------------------------------------------------
MQTT_URI=mqtt://2smart-emqx:1883

# Root MQTT credentials. Generate strong random strings.
MQTT_ROOT_USERNAME=2smart
MQTT_ROOT_PASSWORD=CHANGE_ME_mqtt_root_password

# Credentials for the Yahoo weather bridge (optional; required only if you use it).
MQTT_YW_USER=yahoo-weather
MQTT_YW_PASSWORD=CHANGE_ME_mqtt_yw_password

# Soft cap on retained MQTT messages cached by the UI.
MQTT_CACHE_LIMIT=15000

# ---------------------------------------------------------------------------
# MySQL
# Internal DB used by 2smart-core. Change ONLY the passwords.
# ---------------------------------------------------------------------------
MYSQL_HOST=2smart-mysql
MYSQL_DATABASE=2smart
MYSQL_USER=2smart
MYSQL_PASSWORD=CHANGE_ME_mysql_user_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_password

# ---------------------------------------------------------------------------
# InfluxDB (time-series)
# ---------------------------------------------------------------------------
INFLUX_HOST=influxdb
INFLUX_DATABASE=influx_db
# How long to keep time-series data, in days.
INFLUX_ROTATION_DAYS=180

# ---------------------------------------------------------------------------
# Client Dashboard / JWT
# ---------------------------------------------------------------------------
# 16+ character random string. Keep this secret — rotating it logs everyone out.
JWT_TOKEN_SECRET=CHANGE_ME_jwt_secret
JWT_TOKEN_AUTO_EXIT_PIN_MAX_AGE=300
JWT_TOKEN_PIN_MAX_AGE=0
JWT_TOKEN_PASSWORD_MAX_AGE=0

# ---------------------------------------------------------------------------
# GitLab image registry (bridges / extensions are pulled from there).
# These are 2smart's public read-only credentials. Leave as-is unless
# you are hosting a private mirror.
# ---------------------------------------------------------------------------
GITLAB_SERVER=gitlab.iot.webbylab.com
GITLAB_SERVER_USER=2smart.dev
GITLAB_SERVER_PASS=xyaVneyenW9iA-vT5X1Q
REGISTRY_SERVER=gitlab.iot.webbylab.com:5050

# ---------------------------------------------------------------------------
# Yahoo Weather (optional).
# ---------------------------------------------------------------------------
YAHOO_APP_ID=
YAHOO_APP_CONSUMER_KEY=
YAHOO_APP_CONSUMER_SECRET=

# ---------------------------------------------------------------------------
# Backups
# ---------------------------------------------------------------------------
BACKUPS_MEMORY_LIMIT=1gb
