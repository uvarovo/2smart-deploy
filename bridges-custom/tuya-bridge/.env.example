# Tuya Device Settings (required)
TUYA_DEVICE_ID=your_device_id
TUYA_LOCAL_KEY="your_local_key"
TUYA_LOCAL_IP=192.168.x.x
TUYA_VERSION=3.5

# MQTT Connection
MQTT_URI=mqtt://localhost:1883
MQTT_USER=2smart
MQTT_PASS=your_mqtt_password

# Device Settings
DEVICE_NAME=My Tuya Device
DEVICE_ID=tuya-sensor
POLL_INTERVAL=30

# Optional: DP Name Mapping
# Format: dpId:Name:unit:min:max,...
# Example for PTH-9CW:
# DP_MAP=2:CO2:ppm:0:5000,18:Temperature:°C:-10:60,19:Humidity:%:0:100
DP_MAP=
